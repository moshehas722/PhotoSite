GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
PORT=3001

# Firestore (@google-cloud/firestore uses Application Default Credentials, not GOOGLE_SERVICE_ACCOUNT_KEY_PATH)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# Path to service account JSON for Firestore/purchases (or omit and use: gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Optional: persist sessions in Firestore while developing (cookie still uses secure=false on http://localhost)
USE_FIRESTORE_SESSIONS=false

# Google OAuth (create an OAuth 2.0 Web application client in Google Cloud Console,
# add http://localhost:5173 as an authorized JavaScript origin)
# You can provide multiple IDs as a comma-separated list if needed.
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id_here
SESSION_SECRET=change_me_to_a_long_random_string
